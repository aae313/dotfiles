(deflisten workspaces :initial ""
  "~/.config/eww/scripts/workspaces.sh")

(defwindow workspace-indicator
  :monitor 1
  :geometry (geometry
    :x "0px"
    :y "0px"
    :width "120px"
    :height "36px"
    :anchor "top right")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (box
    :class "workspace-box"
    workspaces))
