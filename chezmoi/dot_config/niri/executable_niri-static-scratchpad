#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
  printf 'usage: %s APP_ID DESKTOP_FILE\n' "${0##*/}" >&2
  exit 64
fi

app_id="$1"
desktop_file="$2"
app_id_regex="^$(printf '%s' "$app_id" | sed 's/[][\\.^$*+?{}()|]/\\&/g')$"

window_id_for_app() {
  niri msg -j windows | jq -er --arg app_id "$app_id" \
    'first(.[] | select(.app_id == $app_id) | .id)'
}

focused_window_id() {
  niri msg -j focused-window | jq -er '.id'
}

is_scratchpad_window() {
  local window_id="$1"

  nirius list-scratchpad \
    | awk -v window_id="$window_id" '
        $0 ~ ("^id: " window_id ",") { found = 1 }
        END { exit !found }
      '
}

spawn_window() {
  dex "$desktop_file" >/dev/null 2>&1 &

  for _ in {1..100}; do
    if window_id_for_app; then
      return 0
    fi
    sleep 0.1
  done

  return 1
}

window_id="$(window_id_for_app || true)"
if [[ -z "$window_id" ]]; then
  window_id="$(spawn_window)" || {
    printf 'niri-static-scratchpad: no window appeared for app-id: %s\n' "$app_id" >&2
    exit 1
  }
fi

if is_scratchpad_window "$window_id"; then
  if [[ "$(focused_window_id || true)" == "$window_id" ]]; then
    exec nirius scratchpad-show
  fi

  exec nirius scratchpad-show --id "$window_id"
fi

nirius scratchpad-toggle -a "$app_id_regex"
exec nirius scratchpad-show --id "$window_id"
