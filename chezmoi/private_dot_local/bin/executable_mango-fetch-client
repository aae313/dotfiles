#!/usr/bin/env bash
set -euo pipefail

state_dir="${XDG_RUNTIME_DIR:-/tmp}/mango-fetch-client"

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

active_tag() {
  mmsg get all-monitors \
    | jq -er 'first(.monitors[] | select(.active) | .active_tags[] | select(. != 0))'
}

select_client() {
  local rows selection

  rows="$(
    mmsg get all-clients \
      | jq -r '
          .clients[]
          | [
              (.id | tostring),
              (.appid // ""),
              (.title // ""),
              (.monitor // ""),
              (.tags | join(","))
            ]
          | @tsv
        '
  )"

  [[ -n "$rows" ]] || return 1

  selection="$(
    printf '%s\n' "$rows" \
      | fuzzel --dmenu --prompt='Fetch Client: ' --width=100 --lines=24
  )"

  [[ -n "$selection" ]] || return 1
  printf '%s\n' "$selection"
}

fetch_client() {
  local target_tag selection id appid title monitor tags original_tag

  target_tag="$(active_tag)" || die "mango-fetch-client: no active tag"
  selection="$(select_client)" || return 0

  IFS=$'\t' read -r id appid title monitor tags <<<"$selection"
  [[ -n "$id" ]] || die "mango-fetch-client: selected client has no id"

  original_tag="${tags%%,*}"
  [[ -n "$original_tag" ]] || die "mango-fetch-client: selected client has no tag"

  mkdir -p "$state_dir"
  jq -n \
    --argjson id "$id" \
    --argjson original_tag "$original_tag" \
    --arg appid "$appid" \
    --arg title "$title" \
    --arg monitor "$monitor" \
    '{
      id: $id,
      original_tag: $original_tag,
      appid: $appid,
      title: $title,
      monitor: $monitor
    }' >"$state_dir/$id.json"

  mmsg dispatch "tag,$target_tag" "client,$id" >/dev/null
}

unfetch_client() {
  local client id state_file original_tag

  client="$(mmsg get focusing-client)" || return 0
  id="$(jq -er '.id' <<<"$client")" || return 0
  state_file="$state_dir/$id.json"

  [[ -f "$state_file" ]] || return 0
  original_tag="$(jq -er '.original_tag' "$state_file")" || return 0

  mmsg dispatch "tagsilent,$original_tag" "client,$id" >/dev/null
  rm -f "$state_file"
}

case "${1:-}" in
  fetch)
    fetch_client
    ;;
  unfetch)
    unfetch_client
    ;;
  *)
    die "usage: mango-fetch-client fetch|unfetch"
    ;;
esac
