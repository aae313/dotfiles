#!/usr/bin/env nu

def print-error [message: string]: nothing -> nothing {
  print --stderr $message
}

def socket-path [arguments: list<string>]: nothing -> string {
  let existing_socket = $env.NVIM_LISTEN_ADDRESS? | default ""
  if ($existing_socket | is-not-empty) {
    return $existing_socket
  }

  let runtime_dir = $env.XDG_RUNTIME_DIR? | default ""
  if ($runtime_dir | is-empty) {
    print-error "XDG_RUNTIME_DIR not set"
    exec nvim ...$arguments
  }

  $runtime_dir | path join "nvim.sock"
}

def focus-neovide []: nothing -> nothing {
  let window_id = try {
    ^niri msg --json windows
    | from json
    | where app_id? == "neovide"
    | get 0?.id?
  } catch {
    null
  }

  if $window_id == null {
    print-error "Failed to focus neovide"
    return
  }

  let focus = ^niri msg action focus-window --id $window_id | complete
  if $focus.exit_code != 0 {
    print-error "Failed to focus neovide"
  }
}

def expand-path [path: string]: nothing -> string {
  $path | path expand
}

def path-kind [path: string]: nothing -> any {
  $path | path type
}

def open-with-new-server [arguments: list<string> socket: string]: nothing -> nothing {
  ^app2unit -- neovide ...$arguments -- --listen $socket
}

def open-file [path: string socket: string]: nothing -> nothing {
  let absolute_path = expand-path $path

  let socket_exists = (path-kind $socket) == "socket"
  if not $socket_exists {
    open-with-new-server [$absolute_path] $socket
    return
  }

  ^nvim --server $socket --remote $absolute_path
  focus-neovide
}

def pick-file [directory: string extension: string]: nothing -> string {
  let fd_output = if ($extension | is-empty) {
    ^fd . $directory --type f
  } else {
    ^fd . $directory --type f --extension $extension
  }

  try {
    $fd_output | ^fzf | str trim
  } catch {
    ""
  }
}

def select-file [directory: string extension: string]: nothing -> string {
  let kind = path-kind $directory
  if $kind == "file" {
    return $directory
  }

  if $kind != "dir" {
    print-error $"xx: not a directory: ($directory)"
    exit 1
  }

  let selection = pick-file $directory $extension
  if ($selection | is-empty) {
    print-error "xx: no file selected/found"
    exit 1
  }

  $selection
}

def open-picker [directory: string extension: string socket: string]: nothing -> nothing {
  let selection = select-file $directory $extension
  open-file $selection $socket
}

def main [...arguments: string]: nothing -> nothing {
  let socket = socket-path $arguments
  let socket_exists = (path-kind $socket) == "socket"

  if not $socket_exists {
    if ($arguments | length) == 1 and ((path-kind $arguments.0) == "dir") {
      open-picker (expand-path $arguments.0) "" $socket
    } else {
      open-with-new-server $arguments $socket
    }
    return
  }

  if ($arguments | is-empty) {
    open-picker "." "" $socket
    return
  }

  for argument in $arguments {
    let absolute_path = expand-path $argument

    if (path-kind $absolute_path) == "dir" {
      open-picker $absolute_path "" $socket
    } else {
      open-file $absolute_path $socket
    }
  }
}
