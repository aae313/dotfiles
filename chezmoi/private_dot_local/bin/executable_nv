#!/usr/bin/env bash
set -euo pipefail
shopt -s inherit_errexit

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

socket_path() {
  [[ -n "${XDG_RUNTIME_DIR:-}" ]] || return 1
  printf '%s\n' "$XDG_RUNTIME_DIR/nvim.sock"
}

server_alive() {
  local socket="$1"
  local status=0

  [[ -S "$socket" ]] || return 1
  timeout 2 nvim --server "$socket" --remote-expr 1 </dev/null >/dev/null 2>&1 || status=$?

  ((status == 0)) && return 0
  ((status == 124)) && die "nv: nvim server is not responding: $socket"
  return 1
}

expand_path() {
  local path="$1"
  local home_prefix="~"

  if [[ "$path" == "$home_prefix" ]]; then
    printf '%s\n' "$HOME"
  elif [[ "${path:0:2}" == "$home_prefix/" ]]; then
    printf '%s\n' "$HOME/${path#~/}"
  elif [[ "$path" = /* ]]; then
    printf '%s\n' "$path"
  else
    printf '%s\n' "$PWD/$path"
  fi
}

focus_neovide() {
  nirius focus --app-id neovide >/dev/null 2>&1 || true
}

open_with_new_server() {
  local socket="$1"
  shift

  app2unit -- neovide "$@" -- --listen "$socket"
}

open_remote() {
  local socket="$1"
  shift

  local output
  output="$(nvim --server "$socket" --remote "$@" </dev/null 2>&1)" ||
    die "nv: remote open failed: $output"
  focus_neovide
}

pick_file() {
  local directory="$1"

  fd . "$directory" --type f | fzf
}

select_file() {
  local target="$1"
  local selection

  if [[ -f "$target" ]]; then
    printf '%s\n' "$target"
    return
  fi

  [[ -d "$target" ]] || die "nv: not a directory: $target"

  selection="$(pick_file "$target")" || die "nv: no file selected/found"
  [[ -n "$selection" ]] || die "nv: no file selected/found"
  printf '%s\n' "$selection"
}

resolve_path() {
  local target="$1"
  local path

  path="$(expand_path "$target")"

  if [[ -d "$path" ]]; then
    path="$(select_file "$path")"
    path="$(expand_path "$path")"
  fi

  printf '%s\n' "$path"
}

main() {
  local socket

  if ! socket="$(socket_path)"; then
    exec nvim "$@"
  fi

  if ! server_alive "$socket"; then
    rm -f "$socket"

    local arguments=()
    local argument
    for argument in "$@"; do
      if [[ "$argument" == -* ]]; then
        arguments+=("$argument")
      else
        arguments+=("$(resolve_path "$argument")")
      fi
    done

    open_with_new_server "$socket" "${arguments[@]}"
    return
  fi

  if [[ $# -eq 0 ]]; then
    local path
    path="$(resolve_path "$PWD")"
    open_remote "$socket" "$path"
    return
  fi

  local paths=()
  local argument
  for argument in "$@"; do
    paths+=("$(resolve_path "$argument")")
  done

  open_remote "$socket" "${paths[@]}"
}

main "$@"
