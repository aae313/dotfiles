#!/usr/bin/env python3

import json
import os
import subprocess
import sys
from pathlib import Path


BOOKMARKS_PATH = Path.home() / ".config/net.imput.helium/Profile 1/Bookmarks"


def iter_bookmarks(node):
    if node.get("type") == "url":
        title = node.get("name") or node.get("url")
        url = node.get("url")

        if url:
            yield title, url

        return

    for child in node.get("children", []):
        yield from iter_bookmarks(child)


def load_bookmarks(path):
    with path.open("r", encoding="utf-8") as file:
        data = json.load(file)

    seen = set()
    rows = []

    for root in data.get("roots", {}).values():
        for title, url in iter_bookmarks(root):
            if url in seen:
                continue

            seen.add(url)
            rows.append((title, url))

    return rows


def choose_bookmark(rows):
    menu_input = "\n".join(f"{title}\t{url}" for title, url in rows)

    result = subprocess.run(
        [
            "fuzzel",
            "--dmenu",
            "--prompt=Open Bookmark: ",
            "--width=80",
            "--lines=24",
        ],
        input=menu_input,
        text=True,
        stdout=subprocess.PIPE,
    )

    if result.returncode != 0:
        return None

    selection = result.stdout.strip()

    if not selection:
        return None

    return selection.rsplit("\t", 1)[-1]


def main():
    if not BOOKMARKS_PATH.exists():
        print(
            f"open-bookmark: missing Helium bookmarks file: {BOOKMARKS_PATH}",
            file=sys.stderr,
        )
        return 1

    try:
        rows = load_bookmarks(BOOKMARKS_PATH)
    except Exception as error:
        print(f"open-bookmark: failed to read bookmarks: {error}", file=sys.stderr)
        return 1

    if not rows:
        print("open-bookmark: no bookmarks found", file=sys.stderr)
        return 1

    url = choose_bookmark(rows)

    if not url:
        return 0

    try:
        subprocess.Popen(["helium", url])
    except FileNotFoundError:
        print("open-bookmark: helium executable not found", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
