#!/usr/bin/env bash
set -euo pipefail

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

pick_file() {
  local directory="$1"
  local extension="${2:-}"

  if [[ -n "$extension" ]]; then
    fd . "$directory" --type f --extension "$extension" | fzf
  else
    fd . "$directory" --type f | fzf
  fi
}

select_file() {
  local target="$1"
  local extension="$2"
  local selection

  if [[ -f "$target" ]]; then
    printf '%s\n' "$target"
    return
  fi

  [[ -d "$target" ]] || die "xx: not a directory: $target"

  selection="$(pick_file "$target" "$extension")" || die "xx: no file selected/found"
  [[ -n "$selection" ]] || die "xx: no file selected/found"
  printf '%s\n' "$selection"
}

main() {
  local extension=""
  local target="."

  while (($# > 0)); do
    case "$1" in
      -e)
        shift
        (($# > 0)) || die "xx: -e requires argument"
        extension="$1"
        ;;
      --)
        shift
        if (($# > 0)); then
          target="$1"
        fi
        break
        ;;
      -*)
        die "xx: unknown option $1"
        ;;
      *)
        target="$1"
        break
        ;;
    esac

    shift
  done

  local selection
  selection="$(select_file "$target" "$extension")"
  nv "$selection"
}

main "$@"
