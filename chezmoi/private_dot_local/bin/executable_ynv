#!/usr/bin/env bash
set -euo pipefail
server="${1:?missing nvim server address}"
shift

tmp="$(mktemp -t "yazi-chooser.XXXXX")"
trap 'rm -f "$tmp"' EXIT

yazi "$@" --chooser-file="$tmp"

mapfile -t files < <(grep -v '^$' "$tmp")

if ((${#files[@]})); then
  nvim --server "$server" --remote-silent "${files[@]}"
  hyprctl dispatch 'hl.dsp.focus({ window = hl.get_window("class:neovide") })' >/dev/null 2>&1 || true
fi
