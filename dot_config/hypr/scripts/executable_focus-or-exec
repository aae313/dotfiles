#!/bin/sh
class="$1"
shift

if [ -z "$class" ] || [ "$#" -eq 0 ]; then
  echo "usage: focus-or-exec <class> <command> [args...]" >&2
  exit 2
fi

hyprctl dispatch focuswindow "class:$class" >/dev/null 2>&1

if ! hyprctl -j activewindow | jq -e --arg c "$class" '.class == $c' >/dev/null; then
  "$@" &
fi
