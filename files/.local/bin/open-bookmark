#!/usr/bin/env python3

import subprocess
import sys
import sqlite3
from pathlib import Path


PROFILE_PATH = Path.home() / ".config/mozilla/firefox/hey"
BOOKMARKS_PATH = PROFILE_PATH / "places.sqlite"


def load_bookmarks(path):
    connection = sqlite3.connect(f"file:{path}?mode=ro&immutable=1", uri=True)

    try:
        return connection.execute(
            """
            select title, url
            from (
              select
                coalesce(nullif(b.title, ''), p.title, p.url) as title,
                p.url as url,
                b.dateAdded as date_added,
                row_number() over (
                  partition by p.url
                  order by b.dateAdded desc
                ) as url_rank
              from moz_bookmarks b
              join moz_places p on p.id = b.fk
              where b.type = 1
                and p.url like 'http%'
            )
            where url_rank = 1
            order by date_added desc
            """
        ).fetchall()
    finally:
        connection.close()


def choose_bookmark(rows):
    menu_input = "\n".join(f"{title}\t{url}" for title, url in rows)

    result = subprocess.run(
        [
            "fuzzel",
            "--dmenu",
            "--prompt=Open Bookmark: ",
            "--width=80",
            "--lines=24",
        ],
        input=menu_input,
        text=True,
        stdout=subprocess.PIPE,
    )

    if result.returncode != 0:
        return None

    selection = result.stdout.strip()

    if not selection:
        return None

    return selection.rsplit("\t", 1)[-1]


def main():
    if not BOOKMARKS_PATH.exists():
        print(
            f"open-bookmark: missing Firefox bookmarks database: {BOOKMARKS_PATH}",
            file=sys.stderr,
        )
        return 1

    try:
        rows = load_bookmarks(BOOKMARKS_PATH)
    except Exception as error:
        print(f"open-bookmark: failed to read bookmarks: {error}", file=sys.stderr)
        return 1

    if not rows:
        print("open-bookmark: no bookmarks found", file=sys.stderr)
        return 1

    url = choose_bookmark(rows)

    if not url:
        return 0

    try:
        subprocess.Popen(["firefox-nightly", "-profile", str(PROFILE_PATH), url])
    except FileNotFoundError:
        print("open-bookmark: firefox-nightly executable not found", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
